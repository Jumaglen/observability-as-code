      "id": 4,
      "options": {
        "legend": {
          "calcs": ["mean", "max", "min"],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "pluginVersion": "8.0.0",
      "targets": [
        {
          "expr": "(node_filesystem_size_bytes{fstype!=\"tmpfs\",mountpoint=\"/\",market=~\"$market\"} - node_filesystem_avail_bytes{fstype!=\"tmpfs\",mountpoint=\"/\",market=~\"$market\"}) / node_filesystem_size_bytes{fstype!=\"tmpfs\",mountpoint=\"/\",market=~\"$market\"} * 100",
          "format": "time_series",
          "intervalFactor": 1,
          "legendFormat": "{{market}} - {{instance}}",
          "refId": "A"
        }
      ],
      "title": "Disk Usage by Host & Market",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
