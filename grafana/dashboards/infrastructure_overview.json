        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": ["mean", "max", "min"],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "pluginVersion": "8.0.0",
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes{market=~\"$market\"} / node_memory_MemTotal_bytes{market=~\"$market\"})) * 100",
          "format": "time_series",
          "intervalFactor": 1,
          "legendFormat": "{{market}} - {{instance}}",
          "refId": "A"
        }
      ],
      "title": "Memory Usage by Host & Market",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
